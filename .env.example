# Anthropic API key — https://console.anthropic.com
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# kie.ai API key — https://kie.ai/api-key
KIE_API_KEY=your_kie_api_key_here

# Public URL of your model/avatar photo (the "cute model" who will speak in the video)
# Host it on Google Drive, Imgur, Cloudinary, or any public URL
# Must be a direct image link (JPEG or PNG), max 10MB
MODEL_IMAGE_URL=https://your-model-photo-url.jpg

# ElevenLabs voice ID (via kie.ai) — default is "Bella" (warm, bright, female)
# See all voices at: https://docs.kie.ai/market/elevenlabs/text-to-speech-multilingual-v2
# Popular female voices:
#   hpp4J3VqNfWAUOO0d1Us  — Bella    (Professional, Bright, Warm)
#   Z3R5wn05IrDiVCyEkUrK  — Arabella (Mysterious, Emotive)
#   NNl6r8mD7vthiJatiJt1  — Bradford (Expressive, Articulate)
VOICE_ID=hpp4J3VqNfWAUOO0d1Us

# Cloudinary sample/result storage
CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret
CLOUDINARY_SAMPLE_IMAGE_PREFIX=vishleshak-samples/images
CLOUDINARY_SAMPLE_VIDEO_PREFIX=vishleshak-samples/videos
