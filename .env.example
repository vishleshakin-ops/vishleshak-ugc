# Anthropic API key — https://console.anthropic.com
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# kie.ai API key — https://kie.ai/api-key
KIE_API_KEY=your_kie_api_key_here

# Public URL of your model/avatar photo (the "cute model" who will speak in the video)
# Host it on Google Drive, Imgur, Cloudinary, or any public URL
# Must be a direct image link (JPEG or PNG), max 10MB
MODEL_IMAGE_URL=https://your-model-photo-url.jpg

# ElevenLabs voice ID (via kie.ai) — default is "Bella" (warm, bright, female)
# See all voices at: https://docs.kie.ai/market/elevenlabs/text-to-speech-multilingual-v2
# Popular female voices:
#   hpp4J3VqNfWAUOO0d1Us  — Bella    (Professional, Bright, Warm)
#   Z3R5wn05IrDiVCyEkUrK  — Arabella (Mysterious, Emotive)
#   NNl6r8mD7vthiJatiJt1  — Bradford (Expressive, Articulate)
VOICE_ID=hpp4J3VqNfWAUOO0d1Us

# Cloudinary sample/result storage
CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret
CLOUDINARY_SAMPLE_IMAGE_PREFIX=vishleshak-samples/images
CLOUDINARY_SAMPLE_VIDEO_PREFIX=vishleshak-samples/videos

# Credit OTP delivery
# Preferred order is 2Factor/APITXT SMS OTP, then Fast2SMS WhatsApp/SMS, then CallMeBot fallback.
TWOFACTOR_API_KEY=your_2factor_api_key
TWOFACTOR_TEMPLATE_NAME=Vishleshak_UGC
TWOFACTOR_MODE=autogen
TWOFACTOR_OTP_URL_TEMPLATE=https://2factor.in/API/V1/{api_key}/SMS/{phone}/{otp}
TWOFACTOR_AUTOGEN_URL_TEMPLATE=https://2factor.in/API/V1/{api_key}/SMS/{phone}/AUTOGEN/{template_name}
TWOFACTOR_VERIFY_URL_TEMPLATE=https://2factor.in/API/V1/{api_key}/SMS/VERIFY/{session_id}/{otp}
CREDIT_OTP_CHANNEL_ORDER=twofactor,whatsapp,sms,callmebot
FAST2SMS_API_KEY=your_fast2sms_api_key
# Legacy fallback name; prefer CREDIT_OTP_CHANNEL_ORDER.
FAST2SMS_OTP_CHANNEL_ORDER=whatsapp,sms,callmebot

# Option A: Fast2SMS WhatsApp Cloud API template fields
FAST2SMS_WHATSAPP_API_KEY=your_fast2sms_whatsapp_api_key_or_same_as_fast2sms
FAST2SMS_WHATSAPP_VERSION=v24.0
FAST2SMS_WHATSAPP_PHONE_NUMBER_ID=your_whatsapp_phone_number_id
FAST2SMS_WHATSAPP_TEMPLATE_NAME=your_approved_authentication_template_name
FAST2SMS_WHATSAPP_TEMPLATE_LANGUAGE=en_US

# Option B: Fast2SMS downloaded Excel/direct OTP URL.
# Use placeholders: {api_key}, {phone}, {phone_with_country}, {otp}, {variables_values}
FAST2SMS_WHATSAPP_OTP_URL_TEMPLATE=
